# Admin password (required for login)
COUSIN_ADMIN_PASSWORD=change-me-to-something-strong

# Optional: push saves to GitHub (live site repo)
# Create a fine-grained PAT with Contents: Read and write on les-del/cousin-site
# GITHUB_TOKEN=ghp_...
# GITHUB_REPO=les-del/cousin-site
# GITHUB_DATA_PATH=editable/data/directors.json

# Server port (default 8787)
# PORT=8787

# Poster image uploads (uses ~/.aws/credentials if configured, or set explicitly)
# AWS_REGION=ap-southeast-2
# S3_BUCKET=cousin-productions
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
